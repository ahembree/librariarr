# Required — PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/librariarr"

# Optional — session encryption key (32+ characters)
# If not set, one is auto-generated and saved to /config/.session-secret
# SESSION_SECRET="change-me-to-a-random-32-char-string"

# Optional — override backup storage location (default: /config/backups)
# BACKUP_DIR=/config/backups

# Optional — override image cache location (default: /config/cache/images)
# IMAGE_CACHE_DIR=/config/cache/images

# Optional — set the container timezone for scheduled jobs (default: UTC)
# Uses IANA timezone identifiers: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=America/New_York

# Optional — enable debug-level logging output
# LOG_DEBUG=true
