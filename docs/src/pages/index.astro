---
// Landing page — fully custom, outside Starlight's docs layout
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Librariarr — Media Library Management</title>
    <meta
      name="description"
      content="Self-hosted media library management for Plex, Jellyfin, and Emby. Browse, filter, and automate your media with lifecycle rules, stream management, and more."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://librariarr.dev/" />
    <meta property="og:title" content="Librariarr — Media Library Management" />
    <meta property="og:description" content="Self-hosted media library management for Plex, Jellyfin, and Emby. Browse, filter, and automate your media with lifecycle rules, stream management, and more." />
    <meta property="og:image" content="https://librariarr.dev/librariarr_hero.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Librariarr — Media Library Management" />
    <meta name="twitter:description" content="Self-hosted media library management for Plex, Jellyfin, and Emby. Browse, filter, and automate your media with lifecycle rules, stream management, and more." />
    <meta name="twitter:image" content="https://librariarr.dev/librariarr_hero.png" />

    <!-- Structured Data -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Librariarr",
        "applicationCategory": "MultimediaApplication",
        "operatingSystem": "Linux",
        "description": "Self-hosted media library management for Plex, Jellyfin, and Emby. Browse, filter, and automate your media with lifecycle rules, stream management, and more.",
        "url": "https://librariarr.dev",
        "image": "https://librariarr.dev/librariarr_hero.png",
        "license": "https://www.gnu.org/licenses/agpl-3.0.html",
        "isAccessibleForFree": true,
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "codeRepository": "https://github.com/ahembree/librariarr"
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <style>
      /* Reset & base */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: oklch(0.16 0.006 270);
        --bg-card: oklch(0.21 0.008 270);
        --bg-card-hover: oklch(0.25 0.01 270);
        --border: oklch(1 0.01 270 / 12%);
        --border-strong: oklch(1 0.01 270 / 22%);
        --text: oklch(0.95 0.008 80);
        --text-muted: oklch(0.65 0.015 260);
        --accent: oklch(0.6 0.15 250);
        --accent-hover: oklch(0.55 0.18 250);
        --accent-subtle: oklch(0.22 0.04 250);
        --radius: 10px;
        --radius-xl: 14px;
        --max-width: 1140px;
        --font-display: "Sora", sans-serif;
        --font-sans: "Plus Jakarta Sans", sans-serif;
        --font-mono: "JetBrains Mono", monospace;
      }

      html {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
      }

      body {
        overflow-x: hidden;
      }

      section {
        position: relative;
      }

      /* Nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: oklch(0.18 0.008 270 / 70%);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid oklch(1 0 0 / 5%);
      }

      .nav-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .nav-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.02em;
      }

      .nav-links {
        display: flex;
        gap: 1rem;
        align-items: center;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.6rem;
        border-radius: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.2s, background 0.2s;
      }

      .nav-link:hover {
        color: var(--text);
        background: oklch(1 0 0 / 8%);
      }

      .nav-link svg {
        width: 1.125rem;
        height: 1.125rem;
        flex-shrink: 0;
      }

      /* Hero */
      .hero-wrapper {
        position: relative;
        overflow: hidden;
      }

      .hero-gradient {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 50% at 50% -10%, oklch(0.35 0.15 250 / 40%) 0%, transparent 60%),
          radial-gradient(ellipse 60% 40% at 30% 10%, oklch(0.30 0.10 280 / 25%) 0%, transparent 50%),
          radial-gradient(ellipse 60% 40% at 70% 10%, oklch(0.28 0.12 230 / 20%) 0%, transparent 50%);
        pointer-events: none;
      }

      .hero {
        position: relative;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 5.5rem 1.5rem 0;
        text-align: center;
      }

      .hero-badge {
        display: inline-block;
        padding: 0.35rem 1rem;
        border-radius: 999px;
        background: var(--accent-subtle);
        color: var(--accent);
        font-family: var(--font-sans);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        margin-bottom: 1.5rem;
        border: 1px solid oklch(0.35 0.08 250);
      }

      .hero h1 {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.08;
        margin-bottom: 1.25rem;
      }

      .hero h1 .accent {
        background: linear-gradient(135deg, oklch(0.65 0.20 250), oklch(0.55 0.22 280));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero p.lead {
        font-size: 1.15rem;
        color: var(--text-muted);
        max-width: 640px;
        margin: 0 auto 2.25rem;
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.75rem;
        border-radius: 8px;
        font-family: var(--font-sans);
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
      }

      .btn:active {
        transform: scale(0.98);
      }

      .btn-primary {
        background: var(--accent);
        color: #fff;
      }

      .btn-primary:hover {
        background: var(--accent-hover);
      }

      .btn-secondary {
        background: var(--bg-card);
        color: var(--text);
        border: 1px solid var(--border);
      }

      .btn-secondary:hover {
        background: var(--bg-card-hover);
        border-color: var(--border-strong);
      }

      /* Browser-framed screenshot */
      .shot {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--bg-card);
        overflow: hidden;
        box-shadow:
          0 1px 0 oklch(1 0 0 / 6%) inset,
          0 40px 80px -32px oklch(0 0 0 / 80%);
      }

      .shot-bar {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        height: 36px;
        padding: 0 0.85rem;
        background: oklch(0.19 0.008 270);
        border-bottom: 1px solid var(--border);
      }

      .shot-dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: oklch(0.4 0.02 270);
      }

      .shot-dot:nth-child(1) { background: oklch(0.62 0.16 25); }
      .shot-dot:nth-child(2) { background: oklch(0.78 0.14 85); }
      .shot-dot:nth-child(3) { background: oklch(0.68 0.16 145); }

      .shot img {
        display: block;
        width: 100%;
        height: auto;
      }

      /* Hero screenshot */
      .hero-shot {
        position: relative;
        max-width: 1040px;
        margin: 3.5rem auto 0;
        padding: 0 1.5rem;
      }

      .hero-shot::before {
        content: "";
        position: absolute;
        inset: -10% 10% 30%;
        background: radial-gradient(ellipse at center, oklch(0.5 0.18 255 / 35%) 0%, transparent 70%);
        filter: blur(50px);
        z-index: -1;
        pointer-events: none;
      }

      /* Section scaffolding */
      .section {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 5.5rem 1.5rem;
      }

      .section-heading {
        text-align: center;
        max-width: 640px;
        margin: 0 auto 3.5rem;
      }

      .section-eyebrow {
        display: inline-block;
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 0.85rem;
      }

      .section-heading h2 {
        font-family: var(--font-display);
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .section-heading p {
        color: var(--text-muted);
        font-size: 1.05rem;
      }

      /* Feature rows (alternating) */
      .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.5rem;
        align-items: center;
        padding: 3rem 0;
      }

      .feature-row + .feature-row {
        border-top: 1px solid var(--border);
      }

      .feature-row.reverse .feature-copy {
        order: 2;
      }

      .feature-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 1rem;
      }

      .feature-eyebrow svg {
        width: 1.1rem;
        height: 1.1rem;
      }

      .feature-copy h3 {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3vw, 1.9rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin-bottom: 1rem;
      }

      .feature-copy > p {
        color: var(--text-muted);
        font-size: 1.02rem;
        margin-bottom: 1.5rem;
      }

      .feature-list {
        list-style: none;
        display: grid;
        gap: 0.75rem;
      }

      .feature-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        color: var(--text);
        font-size: 0.95rem;
      }

      .feature-list svg {
        width: 1.15rem;
        height: 1.15rem;
        flex-shrink: 0;
        margin-top: 0.15rem;
        color: var(--accent);
      }

      .feature-list strong {
        font-weight: 600;
      }

      .feature-list span {
        color: var(--text-muted);
      }

      /* Bento grid */
      .bento {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
      }

      .bento-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        overflow: hidden;
        transition: border-color 0.3s, background 0.3s, transform 0.3s;
        display: flex;
        flex-direction: column;
      }

      .bento-card:hover {
        border-color: var(--border-strong);
        background: var(--bg-card-hover);
        transform: translateY(-3px);
      }

      .bento-media {
        border-bottom: 1px solid var(--border);
        background: oklch(0.16 0.006 270);
      }

      .bento-media img {
        display: block;
        width: 100%;
        height: auto;
      }

      .bento-body {
        padding: 1.4rem 1.5rem 1.6rem;
      }

      .bento-icon {
        width: 2.1rem;
        height: 2.1rem;
        margin-bottom: 0.9rem;
        color: var(--accent);
      }

      .bento-card h4 {
        font-family: var(--font-display);
        font-size: 1.08rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
      }

      .bento-card p {
        color: var(--text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
      }

      /* Integrations bar */
      .integrations {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem 5rem;
        text-align: center;
      }

      .integrations h2 {
        font-family: var(--font-display);
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
      }

      .integrations > p {
        color: var(--text-muted);
        margin-bottom: 2.5rem;
      }

      .integration-logos {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .integration-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.6rem 1.25rem;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: 999px;
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--text-muted);
        transition: border-color 0.2s, color 0.2s;
      }

      .integration-chip:hover {
        border-color: var(--border-strong);
        color: var(--text);
      }

      /* CTA */
      .cta {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem 6rem;
        text-align: center;
      }

      .cta-box {
        position: relative;
        overflow: hidden;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 3.5rem 2rem;
      }

      .cta-box::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 0%, oklch(0.30 0.10 250 / 30%) 0%, transparent 60%);
        pointer-events: none;
      }

      .cta-box h2 {
        position: relative;
        font-family: var(--font-display);
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .cta-box p {
        position: relative;
        color: var(--text-muted);
        margin-bottom: 2rem;
      }

      .cta-box .hero-actions {
        position: relative;
      }

      /* Footer */
      .footer {
        border-top: 1px solid var(--border);
        padding: 2rem 1.5rem;
        text-align: center;
        color: var(--text-muted);
        font-size: 0.85rem;
      }

      .footer a {
        color: var(--text-muted);
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .footer a:hover {
        color: var(--text);
      }

      /* Responsive */
      @media (max-width: 880px) {
        .feature-row {
          grid-template-columns: 1fr;
          gap: 2rem;
          padding: 2.5rem 0;
        }

        .feature-row.reverse .feature-copy {
          order: 0;
        }

        .bento {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 640px) {
        .hero {
          padding: 4rem 1rem 0;
        }

        .section {
          padding: 4rem 1.25rem;
        }

        .hero-actions {
          flex-direction: column;
          align-items: center;
        }

        .btn {
          width: 100%;
          max-width: 280px;
          justify-content: center;
        }

        .bento {
          grid-template-columns: 1fr;
        }

        .nav-brand span {
          display: none;
        }

        .nav-link span {
          display: none;
        }
      }
    </style>
  </head>

  <body>
    <nav class="nav">
      <div class="nav-inner">
