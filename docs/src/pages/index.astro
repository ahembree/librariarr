---
// Landing page — fully custom, outside Starlight's docs layout
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Librariarr — Media Library Management</title>
    <meta
      name="description"
      content="Self-hosted media library management for Plex, Jellyfin, and Emby. Browse, filter, and automate your media with lifecycle rules, stream management, and more."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://librariarr.dev/" />
    <meta property="og:title" content="Librariarr — Media Library Management" />
    <meta property="og:description" content="Self-hosted media library management for Plex, Jellyfin, and Emby. Browse, filter, and automate your media with lifecycle rules, stream management, and more." />
    <meta property="og:image" content="https://librariarr.dev/librariarr_hero.png" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Librariarr — Media Library Management" />
    <meta name="twitter:description" content="Self-hosted media library management for Plex, Jellyfin, and Emby. Browse, filter, and automate your media with lifecycle rules, stream management, and more." />
    <meta name="twitter:image" content="https://librariarr.dev/librariarr_hero.png" />

    <!-- Structured Data -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Librariarr",
        "applicationCategory": "MultimediaApplication",
        "operatingSystem": "Linux",
        "description": "Self-hosted media library management for Plex, Jellyfin, and Emby. Browse, filter, and automate your media with lifecycle rules, stream management, and more.",
        "url": "https://librariarr.dev",
        "image": "https://librariarr.dev/librariarr_hero.png",
        "license": "https://www.gnu.org/licenses/agpl-3.0.html",
        "isAccessibleForFree": true,
        "offers": {
          "@type": "Offer",
          "price": "0",
          "priceCurrency": "USD"
        },
        "codeRepository": "https://github.com/ahembree/librariarr"
      }
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>
    <style>
      /* Reset & base */
      *,
      *::before,
      *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      :root {
        --bg: oklch(0.16 0.006 270);
        --bg-card: oklch(0.21 0.008 270);
        --bg-card-hover: oklch(0.25 0.01 270);
        --border: oklch(1 0.01 270 / 12%);
        --border-strong: oklch(1 0.01 270 / 22%);
        --text: oklch(0.95 0.008 80);
        --text-muted: oklch(0.65 0.015 260);
        --accent: oklch(0.62 0.2 264);
        --accent-hover: oklch(0.55 0.2 264);
        --accent-subtle: oklch(0.62 0.2 264 / 12%);
        --radius: 10px;
        --radius-xl: 14px;
        --max-width: 1140px;
        --font-display: "Sora", sans-serif;
        --font-sans: "Plus Jakarta Sans", sans-serif;
        --font-mono: "JetBrains Mono", monospace;
      }

      html {
        font-family: var(--font-sans);
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
        scroll-behavior: smooth;
        -webkit-font-smoothing: antialiased;
      }

      body {
        overflow-x: hidden;
      }

      section {
        position: relative;
      }

      /* Nav */
      .nav {
        position: sticky;
        top: 0;
        z-index: 50;
        background: oklch(0.18 0.008 270 / 70%);
        backdrop-filter: blur(20px);
        border-bottom: 1px solid oklch(1 0 0 / 5%);
      }

      .nav-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
      }

      .nav-brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        font-family: var(--font-display);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.02em;
      }

      .nav-links {
        display: flex;
        gap: 1rem;
        align-items: center;
      }

      .nav-link {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.6rem;
        border-radius: 8px;
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.2s, background 0.2s;
      }

      .nav-link:hover {
        color: var(--text);
        background: oklch(1 0 0 / 8%);
      }

      .nav-link svg {
        width: 1.125rem;
        height: 1.125rem;
        flex-shrink: 0;
      }

      /* Hero */
      .hero-wrapper {
        position: relative;
        overflow: hidden;
      }

      .hero-gradient {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 50% at 50% -10%, oklch(0.35 0.15 264 / 40%) 0%, transparent 60%),
          radial-gradient(ellipse 60% 40% at 30% 10%, oklch(0.30 0.10 292 / 25%) 0%, transparent 50%),
          radial-gradient(ellipse 60% 40% at 70% 10%, oklch(0.28 0.12 240 / 20%) 0%, transparent 50%);
        pointer-events: none;
      }

      .hero {
        position: relative;
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 5.5rem 1.5rem 0;
        text-align: center;
      }

      .hero-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        line-height: 1;
        padding: 0.4rem 1rem;
        border-radius: 999px;
        background: var(--accent-subtle);
        color: var(--accent);
        font-family: var(--font-sans);
        font-size: 0.8rem;
        font-weight: 600;
        letter-spacing: 0.03em;
        margin-bottom: 1.5rem;
        border: 1px solid oklch(0.62 0.2 264 / 30%);
      }

      .hero h1 {
        font-family: var(--font-display);
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 800;
        letter-spacing: -0.03em;
        line-height: 1.08;
        margin-bottom: 1.25rem;
      }

      .hero h1 .accent {
        background: linear-gradient(135deg, oklch(0.7 0.2 264), oklch(0.6 0.22 292));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }

      .hero p.lead {
        font-size: 1.15rem;
        color: var(--text-muted);
        max-width: 640px;
        margin: 0 auto 2.25rem;
        line-height: 1.7;
      }

      .hero-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.75rem;
        border-radius: 8px;
        font-family: var(--font-sans);
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        border: none;
      }

      .btn:active {
        transform: translateY(-1px) scale(0.985);
      }

      .btn .arrow {
        transition: transform 0.2s ease;
      }

      .btn:hover .arrow {
        transform: translateX(3px);
      }

      .btn-primary {
        background: var(--accent);
        color: #fff;
        box-shadow: 0 6px 18px -8px color-mix(in oklab, var(--accent) 75%, transparent);
      }

      .btn-primary:hover {
        background: var(--accent-hover);
        transform: translateY(-2px);
        box-shadow: 0 14px 28px -10px color-mix(in oklab, var(--accent) 85%, transparent);
      }

      .btn-secondary {
        background: var(--bg-card);
        color: var(--text);
        border: 1px solid var(--border);
      }

      .btn-secondary:hover {
        background: var(--bg-card-hover);
        border-color: var(--border-strong);
        transform: translateY(-2px);
      }

      /* Browser-framed screenshot */
      .shot {
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        background: var(--bg-card);
        overflow: hidden;
        box-shadow:
          0 1px 0 oklch(1 0 0 / 6%) inset,
          0 40px 80px -32px oklch(0 0 0 / 80%);
      }

      .shot-bar {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        height: 36px;
        padding: 0 0.85rem;
        background: oklch(0.19 0.008 270);
        border-bottom: 1px solid var(--border);
      }

      .shot-dot {
        width: 11px;
        height: 11px;
        border-radius: 50%;
        background: oklch(0.4 0.02 270);
      }

      .shot-dot:nth-child(1) { background: oklch(0.62 0.16 25); }
      .shot-dot:nth-child(2) { background: oklch(0.78 0.14 85); }
      .shot-dot:nth-child(3) { background: oklch(0.68 0.16 145); }

      .shot img {
        display: block;
        width: 100%;
        height: auto;
      }

      /* Hero screenshot */
      .hero-shot {
        position: relative;
        max-width: 1040px;
        margin: 3.5rem auto 0;
        padding: 0 1.5rem;
      }

      .hero-shot::before {
        content: "";
        position: absolute;
        inset: -10% 10% 30%;
        background: radial-gradient(ellipse at center, oklch(0.5 0.18 264 / 35%) 0%, transparent 70%);
        filter: blur(50px);
        z-index: -1;
        pointer-events: none;
      }

      /* Section scaffolding */
      .section {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 5.5rem 1.5rem;
      }

      .section-heading {
        text-align: center;
        max-width: 640px;
        margin: 0 auto 3.5rem;
      }

      .section-eyebrow {
        display: inline-block;
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        margin-bottom: 0.85rem;
      }

      .section-heading h2 {
        font-family: var(--font-display);
        font-size: clamp(1.75rem, 4vw, 2.25rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .section-heading p {
        color: var(--text-muted);
        font-size: 1.05rem;
      }

      /* Feature rows (alternating) */
      .feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3.5rem;
        align-items: center;
        padding: 3rem 0;
      }

      .feature-row + .feature-row {
        border-top: 1px solid var(--border);
      }

      .feature-row.reverse .feature-copy {
        order: 2;
      }

      .feature-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: var(--accent);
        font-size: 0.8rem;
        font-weight: 700;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin-bottom: 1rem;
      }

      .feature-eyebrow svg {
        width: 1.1rem;
        height: 1.1rem;
      }

      .feature-copy h3 {
        font-family: var(--font-display);
        font-size: clamp(1.5rem, 3vw, 1.9rem);
        font-weight: 700;
        letter-spacing: -0.02em;
        line-height: 1.2;
        margin-bottom: 1rem;
      }

      .feature-copy > p {
        color: var(--text-muted);
        font-size: 1.02rem;
        margin-bottom: 1.5rem;
      }

      .feature-list {
        list-style: none;
        display: grid;
        gap: 0.75rem;
      }

      .feature-list li {
        display: flex;
        align-items: flex-start;
        gap: 0.65rem;
        color: var(--text);
        font-size: 0.95rem;
      }

      .feature-list svg {
        width: 1.15rem;
        height: 1.15rem;
        flex-shrink: 0;
        margin-top: 0.15rem;
        color: var(--accent);
      }

      .feature-list strong {
        font-weight: 600;
      }

      .feature-list span {
        color: var(--text-muted);
      }

      /* Bento grid */
      .bento {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.25rem;
      }

      .bento-card {
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        overflow: hidden;
        transition: border-color 0.3s, background 0.3s, transform 0.3s;
        display: flex;
        flex-direction: column;
      }

      .bento-card:hover {
        border-color: var(--border-strong);
        background: var(--bg-card-hover);
        transform: translateY(-3px);
      }

      .bento-media {
        border-bottom: 1px solid var(--border);
        background: oklch(0.16 0.006 270);
      }

      .bento-media img {
        display: block;
        width: 100%;
        height: auto;
      }

      .bento-body {
        padding: 1.4rem 1.5rem 1.6rem;
      }

      .bento-icon {
        width: 2.1rem;
        height: 2.1rem;
        margin-bottom: 0.9rem;
        color: var(--accent);
      }

      .bento-card h4 {
        font-family: var(--font-display);
        font-size: 1.08rem;
        font-weight: 600;
        margin-bottom: 0.4rem;
      }

      .bento-card p {
        color: var(--text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
      }

      /* Integrations bar */
      .integrations {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem 5rem;
        text-align: center;
      }

      .integrations h2 {
        font-family: var(--font-display);
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.5rem;
      }

      .integrations > p {
        color: var(--text-muted);
        margin-bottom: 2.5rem;
      }

      .integration-logos {
        display: flex;
        gap: 0.85rem;
        justify-content: center;
        flex-wrap: wrap;
      }

      .integration-chip {
        --brand: var(--text-muted);
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        padding: 0.5rem 1.15rem 0.5rem 0.5rem;
        background: var(--bg-card);
        border: 1px solid color-mix(in oklab, var(--brand) 28%, var(--border));
        border-radius: 999px;
        font-size: 0.92rem;
        font-weight: 600;
        color: var(--text);
        transition: border-color 0.2s, color 0.2s, background 0.2s, box-shadow 0.25s,
          transform 0.2s;
      }

      .integration-chip:hover {
        transform: translateY(-2px);
        border-color: color-mix(in oklab, var(--brand) 70%, transparent);
        background: color-mix(in oklab, var(--brand) 9%, var(--bg-card));
        box-shadow: 0 12px 26px -12px color-mix(in oklab, var(--brand) 65%, transparent);
      }

      .integration-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.85rem;
        height: 1.85rem;
        border-radius: 50%;
        color: var(--brand);
        background: color-mix(in oklab, var(--brand) 16%, transparent);
        border: 1px solid color-mix(in oklab, var(--brand) 32%, transparent);
        transition: background 0.2s, color 0.2s, transform 0.2s;
      }

      .integration-icon svg {
        width: 1.05rem;
        height: 1.05rem;
      }

      .integration-chip:hover .integration-icon {
        background: var(--brand);
        color: var(--bg);
        transform: scale(1.05);
      }

      /* CTA */
      .cta {
        max-width: var(--max-width);
        margin: 0 auto;
        padding: 0 1.5rem 6rem;
        text-align: center;
      }

      .cta-box {
        position: relative;
        overflow: hidden;
        background: var(--bg-card);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 3.5rem 2rem;
      }

      .cta-box::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(ellipse 80% 60% at 50% 0%, oklch(0.30 0.10 264 / 30%) 0%, transparent 60%);
        pointer-events: none;
      }

      .cta-box h2 {
        position: relative;
        font-family: var(--font-display);
        font-size: 1.75rem;
        font-weight: 700;
        letter-spacing: -0.02em;
        margin-bottom: 0.75rem;
      }

      .cta-box p {
        position: relative;
        color: var(--text-muted);
        margin-bottom: 2rem;
      }

      .cta-box .hero-actions {
        position: relative;
      }

      /* Accessibility */
      .skip-link {
        position: absolute;
        left: 0.75rem;
        top: 0.5rem;
        z-index: 100;
        padding: 0.5rem 0.9rem;
        border-radius: 8px;
        background: var(--accent);
        color: #fff;
        font-weight: 600;
        font-size: 0.85rem;
        text-decoration: none;
        transform: translateY(-160%);
        transition: transform 0.2s ease;
      }

      .skip-link:focus {
        transform: translateY(0);
      }

      a:focus-visible,
      button:focus-visible,
      .integration-chip:focus-visible,
      [tabindex]:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 3px;
        border-radius: 6px;
      }

      /* Nav CTA */
      .nav-cta {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0.45rem 0.95rem;
        border-radius: 8px;
        background: var(--accent);
        color: #fff;
        font-size: 0.85rem;
        font-weight: 600;
        text-decoration: none;
        transition: background 0.2s, transform 0.2s, box-shadow 0.2s;
      }

      .nav-cta:hover {
        background: var(--accent-hover);
        transform: translateY(-1px);
        box-shadow: 0 8px 18px -8px color-mix(in oklab, var(--accent) 85%, transparent);
      }

      .nav-cta .arrow {
        transition: transform 0.2s ease;
      }

      .nav-cta:hover .arrow {
        transform: translateX(2px);
      }

      /* Live dot in the hero badge */
      .badge-dot {
        flex-shrink: 0;
        width: 0.5rem;
        height: 0.5rem;
        border-radius: 50%;
        background: oklch(0.72 0.17 150);
        box-shadow: 0 0 0 0 oklch(0.72 0.17 150 / 60%);
        animation: badge-pulse 2.4s ease-out infinite;
      }

      @keyframes badge-pulse {
        0% { box-shadow: 0 0 0 0 oklch(0.72 0.17 150 / 55%); }
        70% { box-shadow: 0 0 0 6px oklch(0.72 0.17 150 / 0%); }
        100% { box-shadow: 0 0 0 0 oklch(0.72 0.17 150 / 0%); }
      }

      /* Scroll-reveal — only active when JS is present (no-JS shows everything) */
      .js .reveal,
      .js [data-reveal-stagger] > * {
        opacity: 0;
        transform: translateY(20px);
        transition: opacity 0.7s cubic-bezier(0.22, 0.61, 0.36, 1),
          transform 0.7s cubic-bezier(0.22, 0.61, 0.36, 1);
        transition-delay: var(--reveal-delay, 0ms);
        will-change: opacity, transform;
      }

      .js .reveal.in,
      .js [data-reveal-stagger] > .in {
        opacity: 1;
        transform: none;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
        .badge-dot {
          animation: none;
        }
        .js .reveal,
        .js [data-reveal-stagger] > * {
          opacity: 1 !important;
          transform: none !important;
          transition: none !important;
        }
      }

      /* Footer */
      .footer {
        border-top: 1px solid var(--border);
        padding: 3rem 1.5rem 2.5rem;
        color: var(--text-muted);
        font-size: 0.85rem;
      }

      .footer-inner {
        max-width: var(--max-width);
        margin: 0 auto;
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1.25rem;
      }

      .footer-brand {
        font-family: var(--font-display);
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--text);
        text-decoration: none;
        letter-spacing: -0.02em;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
      }

      .footer-links a {
        color: var(--text-muted);
        text-decoration: none;
        transition: color 0.2s;
      }

      .footer-links a:hover {
        color: var(--text);
      }

      .footer-copy {
        width: 100%;
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid var(--border);
        font-size: 0.8rem;
      }

      .footer-copy a {
        color: var(--text-muted);
        text-decoration: underline;
        text-underline-offset: 2px;
      }

      .footer-copy a:hover {
        color: var(--text);
      }

      @media (max-width: 640px) {
        .footer-inner {
          flex-direction: column;
          text-align: center;
        }
        .footer-links {
          justify-content: center;
        }
      }

      /* Lightbox */
      .shot img,
      .bento-media img {
        cursor: zoom-in;
      }

      .shot img:focus-visible,
      .bento-media img:focus-visible {
        outline: 2px solid var(--accent);
        outline-offset: 2px;
      }

      .lightbox {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: clamp(1rem, 4vw, 3rem);
        background: oklch(0.1 0.005 270 / 82%);
        backdrop-filter: blur(8px);
        opacity: 0;
        visibility: hidden;
        transition: opacity 0.25s ease, visibility 0.25s ease;
        cursor: zoom-out;
      }

      .lightbox.open {
        opacity: 1;
        visibility: visible;
      }

      .lightbox img {
        max-width: min(1280px, 100%);
        max-height: 88vh;
        width: auto;
        height: auto;
        border-radius: 12px;
        border: 1px solid var(--border-strong);
        box-shadow: 0 40px 90px -20px oklch(0 0 0 / 85%);
        transform: scale(0.97);
        transition: transform 0.25s ease;
        cursor: default;
      }

      .lightbox.open img {
        transform: scale(1);
      }

      .lightbox-close {
        position: absolute;
        top: clamp(1rem, 3vw, 1.5rem);
        right: clamp(1rem, 3vw, 1.5rem);
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        padding: 0;
        border-radius: 8px;
        border: 1px solid var(--border);
        background: var(--bg-card);
        color: var(--text);
        cursor: pointer;
        transition: background 0.2s, border-color 0.2s;
      }

      .lightbox-close:hover {
        background: var(--bg-card-hover);
        border-color: var(--border-strong);
      }

      .lightbox-close svg {
        width: 1.25rem;
        height: 1.25rem;
      }

      @media (prefers-reduced-motion: reduce) {
        .lightbox,
        .lightbox img {
          transition: none;
        }
      }

      /* Responsive */
      @media (max-width: 880px) {
        .feature-row {
          grid-template-columns: 1fr;
          gap: 2rem;
          padding: 2.5rem 0;
        }

        .feature-row.reverse .feature-copy {
          order: 0;
        }

        .bento {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 640px) {
        .hero {
          padding: 4rem 1rem 0;
        }

        .section {
          padding: 4rem 1.25rem;
        }

        .hero-actions {
          flex-direction: column;
          align-items: center;
        }

        .btn {
          width: 100%;
          max-width: 280px;
          justify-content: center;
        }

        .bento {
          grid-template-columns: 1fr;
        }

        .nav-brand span {
          display: none;
        }

        .nav-link span {
          display: none;
        }

        /* The full CTA overflows narrow viewports — keep just the arrow's
           tap target wording short and the row inside the screen */
        .nav-links {
          gap: 0.5rem;
        }

        .nav-cta {
          padding: 0.45rem 0.75rem;
        }

        .nav-cta .arrow {
          display: none;
        }
      }
