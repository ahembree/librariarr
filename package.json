{
  "name": "librariarr",
  "version": "0.1.0",
  "private": true,
  "description": "Media library management for Plex, Jellyfin, and Emby",
  "repository": {
    "type": "git",
    "url": "https://github.com/ahembree/librariarr.git"
  },
  "homepage": "https://librariarr.dev",
  "license": "AGPL-3.0-only",
  "author": "Aidan Hembree",
  "keywords": [
    "plex",
    "jellyfin",
    "emby",
    "media",
    "library",
    "lifecycle",
    "docker"
  ],
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "VITEST_SKIP_DB_SETUP=true vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "docker:dev": "docker compose -f docker-compose.dev.yml up --build",
    "docker:dev:detach": "docker compose -f docker-compose.dev.yml up --build -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:dev:logs": "docker compose -f docker-compose.dev.yml logs -f librariarr-dev",
    "docker:dev:db:migrate": "docker compose -f docker-compose.dev.yml exec librariarr-dev npx prisma migrate dev",
    "docker:dev:db:push": "docker compose -f docker-compose.dev.yml exec librariarr-dev npx prisma db push",
    "docker:dev:db:studio": "docker compose -f docker-compose.dev.yml exec librariarr-dev npx prisma studio",
    "docker:dev:db:reset": "docker compose -f docker-compose.dev.yml exec librariarr-dev npx prisma migrate reset --force",
    "docker:dev:rebuild": "docker compose -f docker-compose.dev.yml up --build --force-recreate",
    "docker:dev:clean": "docker compose -f docker-compose.dev.yml down -v",
    "docker:build": "docker build -t ahembree/librariarr:latest -t ahembree/librariarr:$(node -p \"require('./package.json').version\") .",
    "docker:push": "docker push ahembree/librariarr:latest && docker push ahembree/librariarr:$(node -p \"require('./package.json').version\")",
    "docs:dev": "npm run --prefix docs dev",
    "docs:build": "npm run --prefix docs build",
    "docs:preview": "npm run --prefix docs preview",
    "prepare": "husky"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.18",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cron-parser": "^5.5.0",
    "embla-carousel-react": "^8.6.0",
    "iron-session": "^8.0.4",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "node-cron": "^4.2.1",
    "pg": "^8.16.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "recharts": "^3.7.0",
    "sharp": "^0.33.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "prisma": "^7.5.0",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
