node_modules
.next
.git
.github

# Environment
.env*

# IDE and tooling
.vscode
.claude
.serena
.mcp.json
.DS_Store

# Docker (don't send compose/dev files into production build context)
docker-compose*.yml
Dockerfile.dev

# Tests and dev-only configs
tests
vitest.config.ts
commitlint.config.ts
.husky

# Browser E2E (Playwright) — never part of the production image. @playwright/test
# is a devDependency and is not traced into the Next.js standalone output; these
# entries also keep the build context small.
e2e
playwright.config.ts
playwright-report
test-results
blob-report

# Recovery scripts are intentionally NOT bundled into the production image.
# An admin running auth recovery is expected to `docker cp` the file in
# temporarily and remove it afterward; this keeps it out of the running
# container's blast radius if the container is ever compromised. See
# docs/src/content/docs/docs/advanced/sso.mdx for usage.
scripts

# Documentation
*.md
docs
