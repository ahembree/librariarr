generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  plexId           String?           @unique
  plexToken        String?
  localUsername     String?           @unique
  passwordHash     String?
  email            String?
  username         String
  sessionVersion   Int               @default(0)
  ssoSubject       String?
  ssoIssuer        String?
  ssoProvider      String?
  ssoEnabled       Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  mediaServers     MediaServer[]
  ruleSets         RuleSet[]
  collections      Collection[]
  appSettings      AppSettings?
  sonarrInstances  SonarrInstance[]
  radarrInstances  RadarrInstance[]
  lidarrInstances  LidarrInstance[]
  seerrInstances   SeerrInstance[]
  tautulliInstances TautulliInstance[]
  lifecycleActions      LifecycleAction[]
  lifecycleExceptions  LifecycleException[]
  blackoutSchedules    BlackoutSchedule[]
  prerollPresets      PrerollPreset[]
  prerollSchedules   PrerollSchedule[]
  savedQueries       SavedQuery[]

  // SSO subjects are only unique per-issuer. Two users can have sub "abc" if
  // they came from different IdPs. This composite key prevents the cross-IdP
  // collision attack where switching the configured IdP could let a stranger
  // log in as the linked admin.
  @@unique([ssoSubject, ssoIssuer])
}

model AppSettings {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  syncSchedule      String    @default("DAILY")
  lastScheduledSync DateTime?
  accentColor       String    @default("default")
  logRetentionDays  Int       @default(7)
  lifecycleDetectionSchedule      String    @default("EVERY_6H")
  lastScheduledLifecycleDetection DateTime?
  lifecycleExecutionSchedule      String    @default("EVERY_6H")
  lastScheduledLifecycleExecution DateTime?
  dashboardLayout   Json?
  columnPreferences       Json?
  cardDisplayPreferences  Json?
  chipColors              Json?
  maintenanceMode              Boolean   @default(false)
  maintenanceMessage           String    @default("")
  maintenanceDelay             Int       @default(30)
  transcodeManagerEnabled      Boolean   @default(false)
  transcodeManagerMessage      String    @default("")
  transcodeManagerDelay        Int       @default(30)
  transcodeManagerCriteria     Json?
  // Discord notifications
  discordWebhookUrl            String?
  discordWebhookUsername       String?
  discordWebhookAvatarUrl      String?
  discordNotifyMaintenance     Boolean   @default(false)
  localAuthEnabled       Boolean @default(false)
  // Allow signing in with Plex from the login page. When false, the Plex
  // button is hidden and /api/auth/plex/token rejects logins — but the
  // user's plexToken stays attached for media server / library sync.
  plexLoginEnabled       Boolean @default(true)
  // SSO — when ssoEnabled is true, the local username/password form is hidden
  // on the login screen. Plex login remains available if a Plex account is linked.
  ssoEnabled                Boolean   @default(false)
  ssoMode                   String    @default("OIDC")
  oidcIssuer                String?
  oidcClientId              String?
  oidcClientSecret          String?
  oidcScopes                String    @default("openid profile email")
  oidcUsernameClaim         String    @default("preferred_username")
  forwardAuthUserHeader     String    @default("Remote-User")
  forwardAuthEmailHeader    String    @default("Remote-Email")
  forwardAuthNameHeader     String    @default("Remote-Name")
  // Single-step undo for SSO config changes. Snapshotted on every PUT to
  // /api/settings/sso. Resistant to backup rotation — gives admins a
  // recovery path when bad credentials are saved and the only available
  // backups all have the broken state.
  previousSsoConfig         Json?
  preferredTitleServerId   String?
  preferredArtworkServerId String?
  // Backup
  backupSchedule                String    @default("DAILY")
  backupRetentionCount          Int       @default(7)
  backupEncryptionPassword      String?
  lastBackupAt                  DateTime?
  // User exclusion lists
  maintenanceExcludedUsers      String[]  @default([])
  transcodeManagerExcludedUsers String[]  @default([])
  // Scheduling
  scheduledJobTime              String    @default("00:00")
  // Display
  dedupStats                    Boolean   @default(true)
  // Retention
  actionHistoryRetentionDays    Int       @default(30)
  // Deletion stats
  deletionStatsResetAt          DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

enum MediaServerType {
  PLEX
  JELLYFIN
  EMBY
}

model MediaServer {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          MediaServerType @default(PLEX)
  name          String
  url           String
  externalUrl   String?
  accessToken   String
  machineId     String?
  tlsSkipVerify Boolean         @default(false)
  enabled       Boolean         @default(true)
  libraries     Library[]
  syncJobs      SyncJob[]
  watchHistory  WatchHistory[]
  tautulliInstances TautulliInstance[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

// A Tautulli instance (Plex monitoring/stats). Tied 1:1 to a Plex MediaServer
// via the optional mediaServerId FK — Tautulli monitors a single Plex server,
// and its richer watch history (transcode decisions, per-session stream detail,
// ip/geo) is ingested into WatchHistory and correlated against the Plex history.
model TautulliInstance {
  id            String       @id @default(cuid())
  userId        String
  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaServerId String?
  mediaServer   MediaServer? @relation(fields: [mediaServerId], references: [id], onDelete: SetNull)
  name          String
  url           String
  apiKey        String
  enabled       Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([userId])
  @@index([mediaServerId])
}

model SonarrInstance {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  url              String
  apiKey           String
  externalUrl      String?
  enabled          Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId])
}

model RadarrInstance {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  url              String
  apiKey           String
  externalUrl      String?
  enabled          Boolean           @default(true)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([userId])
}

model LidarrInstance {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  url         String
  apiKey      String
  externalUrl String?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model SeerrInstance {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  url       String
  apiKey    String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

enum LibraryType {
  MOVIE
  SERIES
  MUSIC
}

model Library {
  id            String       @id @default(cuid())
  mediaServerId String?
  mediaServer   MediaServer? @relation(fields: [mediaServerId], references: [id], onDelete: SetNull)
  key           String
  title         String
  type          LibraryType
  enabled       Boolean      @default(true)
  lastSyncedAt  DateTime?
  mediaItems    MediaItem[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@unique([mediaServerId, key])
}

model MediaItem {
  id               String                @id @default(cuid())
  libraryId        String
  library          Library               @relation(fields: [libraryId], references: [id], onDelete: Cascade)
  ratingKey              String
  parentRatingKey        String?
  grandparentRatingKey   String?
  title            String
  year             Int?
  type             LibraryType
  summary          String?
  thumbUrl         String?
  artUrl           String?
  parentThumbUrl   String?
  parentSummary    String?
  seasonThumbUrl   String?
  parentTitle      String?
  albumTitle       String?
  seasonNumber     Int?
  episodeNumber    Int?
  // Content metadata
  contentRating    String?
  rating           Float?
  audienceRating   Float?
  userRating       Float?
  studio           String?
  tagline          String?
  originalTitle    String?
  originallyAvailableAt DateTime?
  viewOffset       Int?
  // Genres, directors, etc. stored as JSON arrays of tag names
  genres           Json?
  directors        Json?
  writers          Json?
  roles            Json?
  countries        Json?
  // Video metadata
  resolution       String?
  videoWidth       Int?
  videoHeight      Int?
  videoCodec       String?
  videoProfile     String?
  videoFrameRate   String?
  videoBitDepth    Int?
  videoBitrate     Int?
  videoColorPrimaries    String?
  videoColorRange        String?
  videoChromaSubsampling String?
  aspectRatio      String?
  scanType         String?
  // Audio metadata
  audioCodec       String?
  audioChannels    Int?
  audioProfile     String?
  audioBitrate     Int?
  audioSamplingRate Int?
  // File metadata
  container        String?
  dynamicRange     String?
  optimizedForStreaming Boolean?
  fileSize         BigInt?
  filePath         String?
  duration         Int?
  // Enriched metadata (from per-item endpoint)
  titleSort            String?
  ratingCount          Int?
  ratingImage          String?
  audienceRatingImage  String?
  absoluteIndex        Int?
  chapterSource        String?
  labels               Json?
  videoRangeType       String?
  // Playback
  playCount        Int                   @default(0)
  lastPlayedAt     DateTime?
  addedAt          DateTime?
  serverUpdatedAt  DateTime?
  // Dedup
  dedupKey         String?
  dedupCanonical   Boolean               @default(true)
  isWatchlisted    Boolean               @default(false)
  streams          MediaStream[]
  externalIds      MediaItemExternalId[]
  lifecycleActions    LifecycleAction[]
  lifecycleExceptions LifecycleException[]
  ruleMatches        RuleMatch[]
  watchHistory       WatchHistory[]
  createdAt          DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@unique([libraryId, ratingKey])
  @@index([type])
  @@index([type, title])
  @@index([dedupKey])
  @@index([type, dedupCanonical, title])
  @@index([resolution])
  @@index([playCount])
  @@index([lastPlayedAt])
  @@index([parentTitle])
  @@index([albumTitle])
  @@index([contentRating])
  @@index([contentRating, type])
  @@index([studio])
  @@index([studio, type])
  @@index([addedAt])
  @@index([videoCodec, type])
  @@index([audioCodec, type])
  @@index([dynamicRange, type])
  @@index([container, type])
  @@index([originallyAvailableAt])
  @@index([year, type])
  @@index([isWatchlisted, type])
}

model MediaItemExternalId {
  id          String    @id @default(cuid())
  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  source      String
  externalId  String
  createdAt   DateTime  @default(now())

  @@unique([mediaItemId, source])
  @@index([source, externalId])
}

model MediaStream {
  id                    String    @id @default(cuid())
  mediaItemId           String
  mediaItem             MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  streamType            Int       // 1=video, 2=audio, 3=subtitle
  index                 Int?
  codec                 String?
  profile               String?
  bitrate               Int?
  isDefault             Boolean   @default(false)
  displayTitle          String?
  extendedDisplayTitle  String?
  language              String?
  languageCode          String?
  // Video
  width                 Int?
  height                Int?
  frameRate             Float?
  scanType              String?
  colorPrimaries        String?
  colorRange            String?
  chromaSubsampling     String?
  bitDepth              Int?
  videoRangeType        String?
  // Audio
  channels              Int?
  samplingRate          Int?
  audioChannelLayout    String?
  // Subtitle
  forced                Boolean?
  createdAt             DateTime  @default(now())

  @@index([mediaItemId])
  @@index([mediaItemId, streamType])
}

enum SyncJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

model SyncJob {
  id             String        @id @default(cuid())
  mediaServerId  String
  mediaServer    MediaServer   @relation(fields: [mediaServerId], references: [id], onDelete: Cascade)
  status          SyncJobStatus @default(PENDING)
  cancelRequested Boolean       @default(false)
  startedAt       DateTime      @default(now())
  completedAt    DateTime?
  error          String?
  itemsProcessed Int           @default(0)
  totalItems     Int           @default(0)
  currentLibrary String?

  @@index([mediaServerId, status])
}

model RuleSet {
  id                    String            @id @default(cuid())
  userId                String
  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  type                  LibraryType
  rules                 Json
  enabled               Boolean           @default(true)
  seriesScope           Boolean           @default(true)
  actionEnabled         Boolean           @default(false)
  actionType            String?
  actionDelayDays       Int               @default(7)
  arrInstanceId         String?
  targetQualityProfileId Int?
  addImportExclusion    Boolean           @default(false)
  searchAfterAction     Boolean           @default(false)
  addArrTags            String[]          @default([])
  removeArrTags         String[]          @default([])
  collectionId          String?
  collection            Collection?       @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  discordNotifyOnAction Boolean           @default(false)
  discordNotifyOnMatch  Boolean           @default(false)
  stickyMatches         Boolean           @default(false)
  serverIds             String[]          @default([])
  lifecycleActions      LifecycleAction[]
  ruleMatches           RuleMatch[]
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([collectionId])
}

// A reusable, named Plex collection definition that multiple RuleSets can sync
// into ("merge"). Owns the collection-level presentation settings (sort order,
// sort title, home-screen / recommended visibility) so that every rule feeding
// the same collection shares one source of truth. Scoped by LibraryType because
// a Plex collection lives inside a single library type (Movies/Series/Music).
model Collection {
  id          String      @id @default(cuid())
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  type        LibraryType
  sortName    String?
  homeScreen  Boolean     @default(false)
  recommended Boolean     @default(false)
  sort        String      @default("ALPHABETICAL")
  ruleSets    RuleSet[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([userId, type, name])
  @@index([userId])
}

enum LifecycleActionStatus {
  PENDING
  COMPLETED
  FAILED
}

model LifecycleAction {
  id              String                @id @default(cuid())
  userId          String
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItemId          String?
  mediaItem            MediaItem?            @relation(fields: [mediaItemId], references: [id], onDelete: SetNull)
  mediaItemTitle       String?
  mediaItemParentTitle String?
  ruleSetId       String?
  ruleSet         RuleSet?              @relation(fields: [ruleSetId], references: [id], onDelete: SetNull)
  ruleSetName     String?
  ruleSetType     String?
  actionType      String
  status          LifecycleActionStatus @default(PENDING)
  scheduledFor    DateTime
  executedAt      DateTime?
  error           String?
  arrInstanceId        String?
  targetQualityProfileId Int?
  addImportExclusion   Boolean               @default(false)
  searchAfterAction    Boolean               @default(false)
  matchedMediaItemIds  String[]              @default([])
  addArrTags           String[]              @default([])
  removeArrTags        String[]              @default([])
  externalMediaId      Int?
  deletedBytes         BigInt?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([status, scheduledFor])
  @@index([ruleSetId])
  @@index([mediaItemId])
  @@index([userId])
}

model RuleMatch {
  id              String    @id @default(cuid())
  ruleSetId       String
  ruleSet         RuleSet   @relation(fields: [ruleSetId], references: [id], onDelete: Cascade)
  mediaItemId     String
  mediaItem       MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  itemData        Json
  detectedAt      DateTime  @default(now())

  // [ruleSetId] alone is covered by the composite unique's leading column.
  @@unique([ruleSetId, mediaItemId])
}

model LifecycleException {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  mediaItemId String
  mediaItem   MediaItem @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  reason      String?
  createdAt   DateTime  @default(now())

  @@unique([userId, mediaItemId])
  @@index([userId])
}

model SystemConfig {
  id             String   @id @default("singleton")
  plexClientId   String
  setupCompleted Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
}

enum LogCategory {
  BACKEND
  API
  DB
}

model LogEntry {
  id        String      @id @default(cuid())
  level     LogLevel
  category  LogCategory @default(BACKEND)
  source    String
  message   String
  meta      Json?
  createdAt DateTime    @default(now())

  @@index([level])
  @@index([category])
  @@index([source])
  @@index([createdAt])
}

model BlackoutSchedule {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  enabled       Boolean   @default(true)
  scheduleType  String    // "one_time" | "recurring"
  startDate     DateTime?
  endDate       DateTime?
  daysOfWeek    Json?     // [0,1,2,3,4,5,6] where 0=Sunday
  startTime     String?   // "HH:mm"
  endTime       String?   // "HH:mm"
  action        String    // "terminate_immediate" | "warn_then_terminate" | "block_new_only"
  message        String    @default("Stream terminated due to scheduled blackout period.")
  delay          Int       @default(30)
  excludedUsers  String[]  @default([])
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([userId])
  @@index([enabled])
}

model PrerollPreset {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  path      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model PrerollSchedule {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name         String
  enabled      Boolean   @default(true)
  prerollPath  String
  scheduleType String    // "one_time" | "recurring" | "seasonal"
  startDate    DateTime?
  endDate      DateTime?
  daysOfWeek   Json?     // [0..6]
  startTime    String?   // "HH:mm"
  endTime      String?   // "HH:mm"
  priority     Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([userId])
  @@index([enabled])
}

model SavedQuery {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  query     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WatchHistory {
  id              String       @id @default(cuid())
  mediaItemId     String
  mediaItem       MediaItem    @relation(fields: [mediaItemId], references: [id], onDelete: Cascade)
  mediaServerId   String
  mediaServer     MediaServer  @relation(fields: [mediaServerId], references: [id], onDelete: Cascade)
  serverUsername   String
  watchedAt       DateTime?
  deviceName      String?
  platform        String?
  createdAt       DateTime     @default(now())

  // ── Provenance / idempotency ──
  // A play can be sourced from Plex history, Tautulli, or both (merged). The two
  // id columns are the real upsert keys; Postgres treats NULLs as distinct in a
  // unique index, so Plex-only rows (NULL tautulliRowId) and Tautulli-only rows
  // (NULL plexHistoryKey) coexist, while a correlated row carries both.
  source              String    @default("PLEX") // "PLEX" | "TAUTULLI" | "PLEX+TAUTULLI"
  serverHistoryKey    String?   // native media-server history id (Plex historyKey; synthesized for Jellyfin/Emby)
  tautulliRowId       String?   // Tautulli get_history → row_id
  tautulliReferenceId String?   // Tautulli get_history → reference_id (groups paused segments)

  // ── Session / engagement (Tautulli get_history) ──
  startedAt        DateTime?
  stoppedAt        DateTime?
  playDurationSec  Int?       // play_duration — actual seconds watched
  pausedCounter    Int?
  percentComplete  Int?
  ipAddress        String?
  location         String?
  player           String?
  product          String?

  // ── Transcode decision (Tautulli get_history) ──
  transcodeDecision String?   // "direct play" | "copy" | "transcode"
  videoDecision     String?
  audioDecision     String?
  subtitleDecision  String?

  // ── Source (on-disk) tracks — for source→delivered diff (Tautulli get_stream_data) ──
  sourceVideoCodec        String?
  sourceAudioCodec        String?
  sourceContainer         String?
  sourceVideoResolution   String?
  sourceVideoDynamicRange String?

  // ── Delivered stream — what was actually streamed (Tautulli get_stream_data) ──
  streamVideoCodec        String?
  streamAudioCodec        String?
  streamContainer         String?
  streamSubtitleCodec     String?
  streamVideoResolution   String?
  streamVideoBitrate      Int?
  streamAudioBitrate      Int?
  streamBitrate           Int?
  streamVideoDynamicRange String?
  transcodeHwDecode       String?  // HW decode codec name (empty when not HW)
  transcodeHwEncode       String?  // HW encode codec name (empty when not HW)

  @@unique([mediaServerId, serverHistoryKey])
  @@unique([mediaServerId, tautulliRowId])
  @@index([mediaItemId])
  @@index([mediaServerId])
  @@index([serverUsername])
  @@index([watchedAt])
  @@index([deviceName])
  @@index([platform])
  @@index([source])
  @@index([transcodeDecision])
}

